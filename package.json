{
  "name": "projeto_extensao_biblioteca_digital_api",
  "type": "module",
  "private": true,
  "scripts": {
    "start:dev": "bun run --hot src/server.ts",
    "start:dev:debug": "bun run --hot --inspect src/server.ts",
    "db:codegen": "kysely-codegen",
    "docs:compile": "tsp compile docs/api/main.tsp",
    "migrate:make": "kysely migrate make",
    "migrate:up": "kysely migrate up",
    "migrate:down": "kysely migrate down",
    "migrate:status": "kysely migrate status",
    "test": "bun test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@typespec/compiler": "^1.11.0",
    "@typespec/http": "^1.11.0",
    "@typespec/openapi3": "^1.11.0",
    "@typespec/rest": "^0.81.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.20.0",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "awilix": "^13.0.3",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}
