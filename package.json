{
  "name": "projeto_extensao_biblioteca_digital_api",
  "type": "module",
  "private": true,
  "scripts": {
    "start:dev": "bun run --hot src/server.ts",
    "start:dev:debug": "bun run --hot --inspect src/server.ts",
    "start:dev:docker": "docker compose -f docker-compose.dev.yml up",
    "db:codegen": "kysely-codegen",
    "docs:compile": "tsp compile docs/api/main.tsp",
    "migrate:make": "kysely migrate make",
    "migrate:latest": "kysely migrate latest",
    "migrate:up": "kysely migrate up",
    "migrate:down": "kysely migrate down",
    "migrate:status": "kysely migrate status",
    "db:seed": "bun run src/infra/database/seed.ts",
    "test": "bun test",
    "test:e2e:infra": "docker compose -f docker-compose.test.yml -p biblioteca-e2e up -d postgres minio rabbitmq && docker compose -f docker-compose.test.yml -p biblioteca-e2e up minio-init",
    "test:e2e:run": "bun --env-file=.env.e2e run migrate:latest && bun --env-file=.env.e2e run db:seed && RUN_E2E=true bun test --env-file=.env.e2e --path-ignore-patterns=\"\" tests/integration/e2e",
    "test:e2e:clean": "docker compose -f docker-compose.test.yml -p biblioteca-e2e down -v",
    "test:e2e": "bun run test:e2e:infra && bun run test:e2e:run && bun run test:e2e:clean",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/bun": "^1.3.12",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/sharp": "^0.32.0",
    "@typespec/compiler": "^1.11.0",
    "@typespec/http": "^1.11.0",
    "@typespec/openapi3": "^1.11.0",
    "@typespec/rest": "^0.81.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.20.0",
    "node-addon-api": "^8.7.0",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "amqplib": "^2.0.1",
    "awilix": "^13.0.3",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "kysely": "^0.28.16",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  }
}
