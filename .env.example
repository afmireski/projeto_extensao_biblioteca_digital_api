DATABASE_URL=postgres://biblioteca:biblioteca@localhost:5432/biblioteca_db
JWT_SECRET=troque-me-por-algo-seguro-de-pelo-menos-32-caracteres
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
CORS_ORIGIN=http://localhost:3000

# Postgres (Docker Compose)
POSTGRES_USER=biblioteca
POSTGRES_PASSWORD=biblioteca
POSTGRES_DB=biblioteca_db
JWT_EXPIRY_DAYS=7

# Storage (MinIO)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_KEY=minioadmin
STORAGE_SECRET=minioadmin
STORAGE_REGION=us-east-1
STORAGE_PATH_STYLE=true

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
OCR_JOB_RETRY_DELAY_MS=300000

# Swagger Documentation Auth
SWAGGER_TOKEN=biblioteca-secreta-token
